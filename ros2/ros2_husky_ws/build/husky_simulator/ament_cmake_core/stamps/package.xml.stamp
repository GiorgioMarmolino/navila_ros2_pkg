<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>husky_simulator</name>
  <version>1.3.2</version>
  <description>Husky Gazebo Simulator</description>

  <maintainer email="federico.rollo@leonardo.com">Federico Rollo</maintainer>

  <license>BSD</license>


  <buildtool_depend>ament_cmake</buildtool_depend>

  <exec_depend version_gte="1.3.0">clearpath_common</exec_depend>
  <exec_depend version_gte="1.0.0">clearpath_viz</exec_depend>
  <exec_depend>husky_bringup</exec_depend>
  <exec_depend>ign_ros2_control</exec_depend>
  <exec_depend>ros_gz</exec_depend>

  <test_depend>ament_lint_auto</test_depend>
  <test_depend>ament_lint_common</test_depend>

  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>
